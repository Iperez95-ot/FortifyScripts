<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd"
        default-init-method="init">

    <bean id="searchAnalysisConfigurer"
          class="com.fortify.manager.DAO.fulltext.SearchAnalysisConfigurer">
    </bean>

    <bean id="searchMappingConfigurer"
          class="com.fortify.manager.DAO.fulltext.SearchMappingConfigurerImpl">
    </bean>

    <!-- Provided as bean so it can be picked by validationListener initialization  -->
    <bean id="hibernateProperties"
          class="org.springframework.beans.factory.config.PropertiesFactoryBean">
        <property name="properties">
            <props>
                <prop key="hibernate.dialect">${db.dialect}</prop>
                <prop key="hibernate.show_sql">false</prop>
                <prop key="hibernate.auto_quote_keyword">${db.autoQuoteKeywords}</prop>
                <prop key="hibernate.cache.region.factory_class">org.hibernate.cache.internal.NoCachingRegionFactory</prop>
                <!-- Hibernate 6: Use dialect's native ID generation strategy -->
                <prop key="hibernate.jpa.compliance.global_id_generators">false</prop>
                <prop key="hibernate.id.new_generator_mappings">false</prop>
                <prop key="max_fetch_depth">0</prop>
                <prop key="hibernate.jdbc.batch_size">100</prop>
                <prop key="hibernate.cache.use_second_level_cache">false</prop>
                <prop key="jakarta.persistence.validation.mode">NONE</prop>
                <!-- Set 2="READ COMMITTED" isolation level as a hibernate default for all DBs: -->
                <prop key="hibernate.connection.isolation">2</prop>
                <!-- removes error from ssc.log during SSC start on Websphere 8.5.5 after upgrade to Hibernate 5 (SSC does not use JTA)  -->
                <prop key="hibernate.transaction.jta.platform">org.hibernate.engine.transaction.jta.platform.internal.NoJtaPlatform</prop>
                <!-- enable hibernate stats collection so they can be exposed via micrometer metrics -->
                <prop key="hibernate.generate_statistics">${actuator.metrics.enabled}</prop>

                <!-- define Lucene version compatibility -->
                <prop key="hibernate.search.backend.lucene_version">#{searchMappingConfigurer.getLuceneVersion()}</prop>
                <prop key="hibernate.search.backend.directory.root">${searchIndex.location}</prop>
                <prop key="hibernate.search.backend.analysis.configurer">#{searchAnalysisConfigurer}</prop>
                <prop key="hibernate.search.mapping.configurer">#{searchMappingConfigurer}</prop>
                <!-- Hibernate 6 changed its mapping for Instant objects to TIMESTAMP_UTC.  We need to keep the older Hibernate5 mapping due to existing DB data. -->
                <prop key="hibernate.type.preferred_instant_jdbc_type">TIMESTAMP</prop>
            </props>
        </property>
    </bean>

    <bean id="sessionFactory" class="org.springframework.orm.hibernate5.LocalSessionFactoryBean">
        <property name="dataSource" ref="dataSource"/>
        <property name="hibernateProperties" ref="hibernateProperties"/>
        <property name="packagesToScan">
            <list>
                <value>com.fortify.manager.DAO</value>
                <value>com.fortify.manager.DAO.**</value>
                <value>com.fortify.objectstore.domain</value>
            </list>
        </property>
    </bean>

    <bean id="transactionManager" class="org.springframework.orm.hibernate5.HibernateTransactionManager">
        <property name="sessionFactory" ref="sessionFactory"/>
    </bean>

    <!-- Enable DataAccessException translation on @Repository classes -->
    <!-- NOTE: This post-processor triggers initialization of all the @Repository and @Entity classes in the
               context.  The CommonIssueDAO entity references static constants from the model, so model
               integration must be initialized before the post-processor runs.
    -->
    <bean class="org.springframework.dao.annotation.PersistenceExceptionTranslationPostProcessor"
            depends-on="initModelIntegration"/>
</beans>
